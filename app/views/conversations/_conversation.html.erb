<div class="group flex items-center rounded-lg <%= selected ? 'bg-gray-200' : 'hover:bg-gray-100' %> transition">
  <%= link_to conversation_path(conversation),
        class: "flex-1 block px-3 py-2 text-sm truncate #{selected ? 'text-gray-900 font-medium' : 'text-gray-700 hover:text-gray-900'}" do %>
    <%= conversation.title || "New Chat" %>
  <% end %>
  <%= button_to conversation_path(conversation),
        method: :delete,
        class: "hidden group-hover:block px-2 py-1 text-gray-400 hover:text-red-500 text-xs",
        data: { turbo_confirm: "Delete this conversation?" } do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  <% end %>
</div>
